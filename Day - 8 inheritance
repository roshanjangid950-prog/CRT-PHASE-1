// problem no. 6
// Encapsulation


#include<iostream>
using namespace std;

class bankaccount{
private:    
    int bankbalance;
public:
    void setbalance(int amount){// setter
        if (amount >=0){
            bankbalance = amount;
        }else{
            cout << " enter a valid amount";
        }
    }
    int getbalance(){ // getter
        return bankbalance;
    }
};

int main(){
    bankaccount obj1;
    obj1. setbalance(50000);
    cout << obj1.getbalance();
}


