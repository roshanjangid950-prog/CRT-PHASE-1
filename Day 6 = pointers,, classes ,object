// problem no. 5
// swapping of 2 variables value using pointers and using function
#include<iostream>
using namespace std;

void swapnumber(int*ptr1 , int*ptr2){
    int temp= *ptr1;
    *ptr1=*ptr2;
    *ptr2=temp;

}
int main(){
    int a,b;
    cin>>a;
    cin>>b;
    swapnumber(&a,&b);
    cout <<a<<" "<< b;
}


