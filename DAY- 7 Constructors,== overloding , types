// problem no. 1
// call by value , call by refrence====
//call by value==  change avalue like a photocopy
// call by refrence== change value directly in the rogram


#include <iostream>
using namespace std;

void updatebyvalue(int a)
{
    a = 500;
}
void updatebyrefrece(int &a)
{
    a = 50;
}
int main()
{
    int original = 100;
    updatebyvalue(original);
    cout << original << "\n";
    updatebyrefrece(original);
    cout << original;
}



